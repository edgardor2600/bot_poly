PORT=4000
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_SERVICE_OR_ANON_KEY
GROQ_API_KEY=YOUR_GROQ_KEY
TAVILY_API_KEY=YOUR_TAVILY_KEY
CRON_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
USE_LOCAL_TIMERS=false
ALLOW_LOCAL_REAL_TRADING=false
BASE_CAPITAL=15
DAILY_GOAL_USDC=1.5
AI_TOP_N=1
MIN_TRADE_USDC=1
MAX_TRADE_USDC=1
MAX_OPEN_TRADES=3
MAX_EXPOSURE_PCT=40
TRADING_RESERVE_USDC=0
TRADING_MIN_POL_BALANCE=0.5
CRITICAL_LOOP_LOCK_TTL_SECONDS=180

# Trade exit policy (recommended for faster realization)
STOP_LOSS_PCT=4
TAKE_PROFIT_PCT=8
BREAK_EVEN_TRIGGER_PCT=3
BREAK_EVEN_BUFFER_PCT=0.25
MAX_HOLD_HOURS=24

# Real trading (disabled by default)
REAL_TRADING_ENABLED=false
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
POLYMARKET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
POLYMARKET_SIGNATURE_TYPE=0
POLYMARKET_FUNDER=0xYOUR_FUNDER_ADDRESS

# Auto-withdraw policy (only works when REAL_TRADING_ENABLED=true)
AUTO_WITHDRAW_ENABLED=true
WITHDRAWAL_TARGET_ADDRESS=0xYOUR_SAFE_WALLET
WITHDRAWAL_OPERATING_CAPITAL_USDC=15
WITHDRAWAL_MIN_EXCESS_USDC=3
WITHDRAWAL_EXCESS_PCT=60
WITHDRAWAL_COOLDOWN_HOURS=24
WITHDRAWAL_MIN_POL_BALANCE=2
WITHDRAWAL_MIN_TRANSFER_USDC=1

# Polygon gas floors (to avoid "gas tip cap below minimum" errors on withdrawal txs)
POLYGON_MIN_PRIORITY_FEE_GWEI=25
POLYGON_MIN_MAX_FEE_GWEI=35
POLYGON_MAX_FEE_CAP_GWEI=200
